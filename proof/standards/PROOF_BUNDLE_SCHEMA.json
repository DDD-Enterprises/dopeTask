{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Dopetask Proof Bundle Schema",
  "description": "Canonical schema for a Dopetask JSON proof bundle.",
  "type": "object",
  "required": [
    "tp_id",
    "status",
    "packet_family",
    "lane",
    "summary",
    "acceptance_checks",
    "validation",
    "artifacts",
    "manifest"
  ],
  "properties": {
    "tp_id": {
      "type": "string",
      "pattern": "^TP-[A-Z0-9]+-[0-9]+$"
    },
    "status": {
      "type": "string"
    },
    "packet_family": {
      "type": "string"
    },
    "lane": {
      "type": "string"
    },
    "summary": {
      "type": "object",
      "required": ["result", "key_findings"],
      "properties": {
        "result": { "type": "string" },
        "key_findings": {
          "type": "array",
          "items": { "type": "string" }
        },
        "key_caveats": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "acceptance_checks": {
      "type": "object",
      "required": ["passed", "failed", "not_applicable"],
      "properties": {
        "passed": {
          "type": "array",
          "items": { "type": "string" }
        },
        "failed": {
          "type": "array",
          "items": { "type": "string" }
        },
        "not_applicable": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "validation": {
      "type": "object",
      "required": ["scenario_count", "scenario_summary", "coverage_notes"],
      "properties": {
        "scenario_count": { "type": "integer" },
        "scenario_summary": {
          "type": "array",
          "items": { "type": "string" }
        },
        "coverage_notes": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "artifacts": {
      "type": "object",
      "required": ["primary", "supporting", "archive"],
      "properties": {
        "primary": {
          "type": "array",
          "items": { "type": "string" }
        },
        "supporting": {
          "type": "array",
          "items": { "type": "string" }
        },
        "archive": {
          "type": "object",
          "required": ["present"],
          "properties": {
            "present": { "type": "boolean" },
            "filename": { "type": ["string", "null"] },
            "sha256": { "type": ["string", "null"] }
          }
        }
      }
    },
    "manifest": {
      "type": "object",
      "required": ["generated_at", "bundle_schema_version"],
      "properties": {
        "generated_at": { "type": "string", "format": "date-time" },
        "bundle_schema_version": { "type": "string" }
      }
    }
  }
}
