{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Dopetask Proof Bundle",
  "type": "object",
  "required": [
    "tp_id",
    "status",
    "summary",
    "acceptance_checks",
    "validation",
    "artifacts",
    "manifest"
  ],
  "properties": {
    "tp_id": { "type": "string" },
    "status": {
      "type": "string",
      "enum": ["VALIDATED", "DEFERRED", "FAILED", "PARTIAL"]
    },
    "packet_family": { "type": "string" },
    "lane": { "type": "string" },
    "summary": {
      "type": "object",
      "required": ["result"],
      "properties": {
        "result": { "type": "string" },
        "key_findings": { "type": "array", "items": { "type": "string" } },
        "key_caveats": { "type": "array", "items": { "type": "string" } }
      }
    },
    "acceptance_checks": {
      "type": "object",
      "properties": {
        "passed": { "type": "array", "items": { "type": "string" } },
        "failed": { "type": "array", "items": { "type": "string" } },
        "not_applicable": { "type": "array", "items": { "type": "string" } }
      }
    },
    "validation": {
      "type": "object",
      "properties": {
        "scenario_count": { "type": "integer" },
        "scenario_summary": { "type": "array", "items": { "type": "string" } },
        "coverage_notes": { "type": "array", "items": { "type": "string" } }
      }
    },
    "decision": {
      "type": "object",
      "properties": {
        "value": {},
        "confidence": {
          "type": "string",
          "enum": ["HIGH", "MEDIUM", "LOW", "INSUFFICIENT"]
        },
        "rationale": { "type": "array", "items": { "type": "string" } }
      }
    },
    "artifacts": {
      "type": "object",
      "properties": {
        "primary": { "type": "array", "items": { "type": "string" } },
        "supporting": { "type": "array", "items": { "type": "string" } },
        "archive": {
          "type": "object",
          "properties": {
            "present": { "type": "boolean" },
            "filename": { "type": "string" },
            "sha256": { "type": "string" }
          }
        }
      }
    },
    "dopetask": {
      "type": "object",
      "properties": {
        "canonical_review_surface": { "type": "boolean", "const": true },
        "supporting_artifacts_retained": { "type": "boolean" },
        "source_manifest": { "type": "string" }
      }
    },
    "manifest": {
      "type": "object",
      "required": ["generated_at", "bundle_schema_version"],
      "properties": {
        "generated_at": { "type": "string", "format": "date-time" },
        "bundle_schema_version": { "type": "string", "pattern": "^\\d+\\.\\d+$" }
      }
    }
  }
}
