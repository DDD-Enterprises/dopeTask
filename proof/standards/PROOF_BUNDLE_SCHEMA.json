{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Dopetask Standard Proof Bundle Schema",
  "description": "Canonical schema for standard proof bundles emitted by ProofAggregator during tp exec and tp series execution.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "tp_id",
    "status",
    "packet_family",
    "lane",
    "summary",
    "acceptance_checks",
    "validation",
    "artifacts",
    "manifest"
  ],
  "properties": {
    "tp_id": {
      "type": "string",
      "pattern": "^TP-[A-Za-z0-9][A-Za-z0-9._-]*$"
    },
    "status": {
      "type": "string"
    },
    "packet_family": {
      "type": "string"
    },
    "lane": {
      "type": "string"
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "result",
        "key_findings",
        "key_caveats"
      ],
      "properties": {
        "result": {
          "type": "string"
        },
        "key_findings": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "key_caveats": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "acceptance_checks": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "passed",
        "failed",
        "not_applicable"
      ],
      "properties": {
        "passed": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "failed": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "not_applicable": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "validation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "scenario_count",
        "scenario_summary",
        "coverage_notes"
      ],
      "properties": {
        "scenario_count": {
          "type": "integer",
          "minimum": 0
        },
        "scenario_summary": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "coverage_notes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "artifacts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "primary",
        "supporting",
        "archive"
      ],
      "properties": {
        "primary": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "supporting": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "archive": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "present",
            "filename",
            "sha256"
          ],
          "properties": {
            "present": {
              "type": "boolean"
            },
            "filename": {
              "type": "string",
              "pattern": "^TP-[A-Za-z0-9][A-Za-z0-9._-]*_PROOF_ARCHIVE\\.zip$"
            },
            "sha256": {
              "type": "string",
              "pattern": "^[0-9a-f]{64}$"
            }
          }
        }
      }
    },
    "manifest": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "generated_at",
        "bundle_schema_version"
      ],
      "properties": {
        "generated_at": {
          "type": "string",
          "format": "date-time"
        },
        "bundle_schema_version": {
          "type": "string",
          "const": "1.0"
        }
      }
    }
  }
}
